---
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Main from "@components/Main.astro";
import BookList from "@components/react/BookList";
import { MAX_RATING, SITE } from "@config";
import books from "@data/book/data.gen.json";
import Layout from "@layouts/Layout.astro";
import { buildBreadcrumbList } from "@utils/jsonLd";

const pathname = Astro.url.pathname;
const pageTitle = "読書記録";

const baseUrl = SITE.website.replace(/\/$/, "");
const bookUrl = `${baseUrl}/book`;

const jsonLd = [
  buildBreadcrumbList([{ name: "読書記録", url: bookUrl }]),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": bookUrl,
    name: "読書記録",
    description: `${SITE.author}が印象に残っている本を記録したオンライン本棚`,
    url: bookUrl,
    isPartOf: { "@id": `${baseUrl}/#website` },
    mainEntity: {
      "@type": "ItemList",
      itemListElement: books.map(
        (
          book: {
            googleAuthors: string[];
            googleDescription: string;
            googleHref: string;
            googleImgSrc: string;
            ISBN: string;
            rating: number;
            title: string;
          },
          i: number,
        ) => ({
          "@type": "ListItem",
          position: i + 1,
          item: {
            "@type": "Book",
            name: book.title,
            author: book.googleAuthors.map((a: string) => ({
              "@type": "Person",
              name: a,
            })),
            isbn: book.ISBN,
            image: book.googleImgSrc,
            url: book.googleHref,
            description: book.googleDescription,
            review: {
              "@type": "Review",
              author: {
                "@type": "Person",
                "@id": `${baseUrl}/#person`,
                name: SITE.author,
              },
              reviewRating: {
                "@type": "Rating",
                ratingValue: book.rating,
                bestRating: MAX_RATING,
                worstRating: 1,
              },
            },
          },
        }),
      ),
    },
  },
];
---

<Layout title={`${SITE.title}${pathname}`} jsonLd={jsonLd}>
  <Header />
  <Main pageTitle={pageTitle}>
    <p class="pt-4 text-sm text-muted-foreground">
      {SITE.author}
      が印象に残っている本を記録したオンライン本棚です。
      <a
        href="https://developers.google.com/books"
        target="_blank"
        class="text-primary hover:underline">
        Google Books APIs
      </a>
      から情報を取得しています。 また、自分の影響度合いに応じてレーティングしています。なお、技術系の本については多岐にわたるため除外しております。
    </p>
    <div class="mt-4 rounded-lg bg-muted/50 p-4">
      <ul class="space-y-1 text-sm text-muted-foreground">
        <li>☆1: いまいちな本</li>
        <li>☆2: 自分の知識を再整理できた本</li>
        <li>☆3: 良書</li>
        <li>☆4: 自分の価値観が広がったおすすめ本</li>
        <li>☆5: 自分の考え方が大きく変わったおすすめ本</li>
      </ul>
    </div>
    <BookList client:only="react" />
  </Main>
  <Footer />
</Layout>
