---
import AboutMe from "@components/AboutMe.astro";
import Education from "@components/Education.astro";
import Footer from "@components/Footer.astro";
import PortfolioLinks from "@components/PortfolioLinks.astro";
import Qualifications from "@components/Qualifications.astro";
import TechStack from "@components/TechStack.astro";
// import achievementsData from "@layouts/Achievements.json";
import Top from "@components/Top.astro";
import WorkExperience from "@components/WorkExperience.astro";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import { PERSON_ENTITY, WEBSITE_ENTITY } from "@utils/jsonLd";

const jsonLd = [WEBSITE_ENTITY, PERSON_ENTITY];
---

<Layout
  title="Portfolio"
  description={`Portfolio of ${SITE.author}.`}
  jsonLd={jsonLd}>
  <main class="dark background main-contents background-grain relative z-10">
    <section>
      <div
        class="bento-grid mx-auto grid grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 lg:grid-cols-3">
        <Top class="order-1 md:col-span-2 lg:col-span-3 lg:order-1" />

        <div class="order-2 col-span-1 md:col-span-2 lg:order-2 lg:col-span-3">
          <div class="grid grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2">
            <AboutMe />
            <PortfolioLinks />
            <TechStack />
          </div>
        </div>

        <WorkExperience class="order-3 lg:order-3" />

        <Education class="order-4 lg:order-4" />

        <Qualifications class="order-5 lg:order-5" />
      </div>
    </section>
    <Footer darkModeDisabled />
  </main>
</Layout>
