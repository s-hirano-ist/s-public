---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Main from "@components/Main.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import { buildArticleJsonLd, buildBreadcrumbList } from "@utils/jsonLd";
import slugify from "@utils/slugify";

export type Props = {
  post: CollectionEntry<"blog">;
};

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: slugify(post.data) },
    props: { post },
  }));
}

const { post } = Astro.props;

const { heading, slug, description, date } = post.data;

const { Content, headings } = await render(post);

const ogUrl = new URL(`${slug}.png`, Astro.url.origin).href;

const baseUrl = SITE.website.replace(/\/$/, "");
const canonicalUrl = `${baseUrl}/blog/${slugify(post.data)}`;

const jsonLd = [
  buildBreadcrumbList([
    { name: "ブログ記事", url: `${baseUrl}/blog` },
    { name: heading, url: canonicalUrl },
  ]),
  buildArticleJsonLd({
    canonicalUrl,
    date,
    description,
    headline: heading,
    body: post.body,
    ogImageUrl: ogUrl,
  }),
];
---

<Layout
  title={heading}
  description={description}
  ogImage={ogUrl}
  jsonLd={jsonLd}>
  <Header />
  <Main publishedDate={date.toLocaleDateString("ja")}>
    <article
      id="article"
      role="article"
      class="prose prose-sm dark:prose-invert mx-auto max-w-5xl sm:prose-base">
      <div class="sm:px-4">
        <TableOfContents headings={headings} />
        <Content />
      </div>
    </article>
  </Main>
  <Footer />
</Layout>
