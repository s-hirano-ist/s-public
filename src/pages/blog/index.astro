---
import { getCollection } from "astro:content";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Main from "@components/Main.astro";
import PostCard from "@components/PostCard.astro";
import { SITE } from "@config";
import externalArticles from "@data/external-articles.json";
import Layout from "@layouts/Layout.astro";
import { buildBreadcrumbList } from "@utils/jsonLd";
import getSortedPosts from "@utils/getSortedPosts";
import slugify from "@utils/slugify";

const pathname = Astro.url.pathname;
const posts = getSortedPosts(await getCollection("blog"));
const pageTitle = "ブロク記事";

const baseUrl = SITE.website.replace(/\/$/, "");
const blogUrl = `${baseUrl}/blog`;

const jsonLd = [
  buildBreadcrumbList([{ name: "ブログ記事", url: blogUrl }]),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": blogUrl,
    name: "ブログ記事",
    description: `${SITE.author}のブログ記事一覧`,
    url: blogUrl,
    isPartOf: { "@id": `${baseUrl}/#website` },
    mainEntity: {
      "@type": "ItemList",
      itemListElement: posts.map((post, i) => ({
        "@type": "ListItem",
        position: i + 1,
        url: `${baseUrl}/blog/${slugify(post.data)}`,
        name: post.data.heading,
      })),
    },
  },
];
---

<Layout title={`${SITE.title} ${pathname}`} jsonLd={jsonLd}>
  <Header />
  <Main pageTitle={pageTitle}>
    <ul>
      {
        posts.map(({ data }) => (
          <PostCard
            href={`${pathname}/${slugify(data)}`}
            title={data.heading}
            description={data.description}
          />
        ))
      }
    </ul>
    <h2 class="mt-12 text-xl font-bold text-foreground">外部記事</h2>
    <ul>
      {
        externalArticles.map(article => (
          <PostCard
            href={article.url}
            title={article.title}
            description={article.description}
            date={article.date}
            external
          />
        ))
      }
    </ul>
  </Main>
  <Footer />
</Layout>
