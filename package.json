{
  "name": "s-public",
  "version": "2.3.1",
  "type": "module",
  "description": "Portfolio and blog pages of s-hirano-ist.",
  "author": "s-hirano-ist",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "astro": "astro",
    "check": "astro check",
    "dev": "doppler run -- astro dev",
    "build": "doppler run -- astro build",
    "preview": "astro preview",
    "sync": "astro sync",
    "tsc": "tsc --noEmit",
    "fmt": "prettier --check **/*.astro .",
    "fmt:fix": "prettier --write **/*.astro .",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "lint:mark": "markdownlint-cli2 **/*.md",
    "lint:mark:fix": "markdownlint-cli2-fix **/*.md",
    "lint:css": "stylelint .",
    "lint:css:fix": "stylelint . --fix",
    "lint:secret": "secretlint --maskSecrets **/*",
    "license:summary": "license-checker-rseidelsohn --summary > license.summary.txt",
    "license:json": "license-checker-rseidelsohn --json > src/data/license/data.gen.json",
    "prepare": "husky",
    "security": "pnpm audit",
    "generate:photo": "tsx script/generate-photo-path.ts",
    "generate:book": "doppler run -- tsx script/generate-book-data.ts",
    "knip": "knip",
    "knip:fix": "knip --fix --allow-remove-files"
  },
  "lint-staged": {
    "*": [
      "pnpm check",
      "pnpm fmt",
      "pnpm lint:secret",
      "pnpm lint:css"
    ],
    "src/**/*.{js,jsx,ts,tsx,astro}": [
      "pnpm tsc",
      "pnpm lint"
    ],
    "**/*.md": "pnpm lint:mark",
    "src/**/*.{css,astro}": "pnpm lint:css"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/react": "5.0.7",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/noto-sans-jp": "5.2.10",
    "@fortawesome/fontawesome-free": "7.2.0",
    "@s-hirano-ist/s-ui": "1.19.9",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.4.4",
    "lenis": "1.3.23",
    "photoswipe": "5.4.4",
    "rehype-autolink-headings": "7.1.0",
    "sanitize-html": "2.17.4",
    "satori": "0.26.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.0",
    "tailwindcss-animated": "2.1.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "8.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@tailwindcss/typography": "0.5.19",
    "@types/react": "19.2.16",
    "@types/sanitize-html": "2.16.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsonc": "3.2.0",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-yml": "3.4.0",
    "husky": "9.1.7",
    "knip": "6.15.0",
    "license-checker-rseidelsohn": "5.0.1",
    "lint-staged": "17.0.7",
    "markdownlint-cli2": "0.22.1",
    "postcss-html": "1.8.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "secretlint": "13.0.2",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "3.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "stylelint-order": "8.1.1",
    "tsx": "4.22.4",
    "typescript-eslint": "8.60.1",
    "vnu-jar": "26.5.29",
    "yaml": "2.9.0"
  }
}
