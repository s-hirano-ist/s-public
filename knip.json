{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/pages/**/*.{astro,ts,tsx}",
    "script/**/*.ts",
    "src/styles/**/*.css"
  ],
  "project": ["src/**/*.{ts,tsx,astro}", "script/**/*.ts"],
  "ignoreDependencies": [
    "@secretlint/secretlint-rule-preset-recommend",
    "astro-eslint-parser",
    "eslint-plugin-redos",
    "vnu-jar"
  ],
  "ignoreBinaries": ["doppler", "markdownlint-cli2-fix"]
}
